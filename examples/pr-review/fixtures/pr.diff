diff --git a/README.md b/README.md
index 83b2e5a..9f41c07 100644
--- a/README.md
+++ b/README.md
@@ -12,6 +12,8 @@ The queue package processes jobs from multiple producers.

 ## Usage

+Workers now run concurrently; set `WORKERS` to control pool size
+(defaults to 4).

 See `examples/` for end-to-end usage.
diff --git a/internal/queue/worker.go b/internal/queue/worker.go
index 2c7d1aa..5e88f3b 100644
--- a/internal/queue/worker.go
+++ b/internal/queue/worker.go
@@ -18,20 +18,26 @@ type Pool struct {
 	jobs    chan Job
 	results map[string]Result
-	mu      sync.Mutex
 }

-// Process runs jobs one at a time.
+// Process runs jobs across the worker pool.
 func (p *Pool) Process(ctx context.Context) error {
-	for job := range p.jobs {
-		res := p.run(ctx, job)
-		p.mu.Lock()
-		p.results[job.ID] = res
-		p.mu.Unlock()
-	}
+	var wg sync.WaitGroup
+	for i := 0; i < p.workers; i++ {
+		go func() {
+			wg.Add(1)
+			defer wg.Done()
+			for job := range p.jobs {
+				res := p.run(ctx, job)
+				p.results[job.ID] = res
+			}
+		}()
+	}
+	wg.Wait()
 	return nil
 }
